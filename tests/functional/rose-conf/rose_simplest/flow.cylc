#!jinja2
[meta]
    title = "Add jinja2 vars from a rose-suite.conf"
    description = """
    Natively, in Cylc!
    """

[cylc]
    [[parameters]]
        member = {{ MEMBERS }}

[scheduling]
    initial cycle point = {{ICP}}
    final cycle point = {{FCP}}
    cycling mode = integer
    [[dependencies]]
        [[[R1]]]
            graph = {{TASK1}} => {{TASK2}}<member> => {{TASK3}}

[runtime]
    [[root]]
        script = echo "This task is ${CYLC_TASK_ID}"

    [[{{TASK1}}]]
    [[{{TASK2}}<member>]]
    [[{{TASK3}}]]